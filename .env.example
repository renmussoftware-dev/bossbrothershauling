# ============================================================================
# Boss Bros Hauling — environment variables (static-site edition)
# Copy to `.env.local` for local dev. On a static host (GitHub Pages) these
# are baked in AT BUILD TIME — re-run `npm run deploy:docs` after changing.
# NEXT_PUBLIC_* values are visible in the shipped JavaScript; that's expected.
# ============================================================================

# --- Lead capture -----------------------------------------------------------
# GitHub Pages has no server, so the form posts straight from the browser to a
# form-capture endpoint. Easiest: create a free Formspree form
# (https://formspree.io), which emails you every lead, then set:
#
#   NEXT_PUBLIC_LEAD_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID
#
# Getform, Basin, Web3Forms, or a Zapier/Make webhook URL also work.
# If left unset, the site falls back to opening the visitor's email app with a
# pre-filled quote request to the business email below — functional, but a
# real endpoint converts far better.
NEXT_PUBLIC_LEAD_ENDPOINT=

# --- Public site config -----------------------------------------------------
NEXT_PUBLIC_BUSINESS_PHONE=(850) 737-0360
NEXT_PUBLIC_BUSINESS_EMAIL=info@bossbrothershauling.com
